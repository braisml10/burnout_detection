<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="14dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="9dp"
        android:background="@drawable/bg_icon_round"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@android:drawable/ic_menu_info_details"
        app:tint="#9AD7FF"/>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/chev"
        android:layout_width="24dp"
        android:layout_height="24dp"
        app:srcCompat="@drawable/ic_chevron_right"
        app:tint="#6E7A94"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/icon"
        app:layout_constraintBottom_toBottomOf="@id/icon"/>

    <TextView
        android:id="@+id/label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:includeFontPadding="true"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="Tiempo de pantalla"
        android:textColor="#B3C0D9"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/icon"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- VALUE: ocupa todo el ancho, y se adapta sin cortarse -->
    <TextView
        android:id="@+id/value"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textStyle="bold"

        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="20sp"
        android:autoSizeMaxTextSize="30sp"
        android:autoSizeStepGranularity="1sp"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/label"
        app:layout_constraintEnd_toStartOf="@id/subvalue"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintWidth_default="spread"
        />

    <!-- SUBVALUE: unidad / sufijo (min, aperturas...), siempre visible -->
    <TextView
        android:id="@+id/subvalue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:gravity="center_vertical"
        android:includeFontPadding="true"
        android:maxLines="1"
        android:ellipsize="end"
        android:text=""
        android:textColor="#6E7A94"
        android:textSize="12sp"
        app:layout_constraintBaseline_toBaselineOf="@id/value"
        app:layout_constraintStart_toEndOf="@id/value"
        app:layout_constraintEnd_toEndOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>
