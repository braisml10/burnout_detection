<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/screenTimeScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#0B1220"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/screenTimeRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Top bar: back + title -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            app:srcCompat="@drawable/ic_chevron_left"
            app:tint="@android:color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Tiempo en pantalla"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBack"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            tools:ignore="HardcodedText" />

        <!-- Day selector row -->
        <ImageButton
            android:id="@+id/btnPrevDay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/transparent"
            app:srcCompat="@drawable/ic_chevron_left"
            app:tint="#94A3B8"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvDayLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hoy"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toTopOf="@id/btnPrevDay"
            app:layout_constraintBottom_toBottomOf="@id/btnPrevDay"
            app:layout_constraintStart_toEndOf="@id/btnPrevDay"
            app:layout_constraintEnd_toStartOf="@id/btnNextDay"
            app:layout_constraintHorizontal_bias="0.5"
            tools:ignore="HardcodedText" />

        <ImageButton
            android:id="@+id/btnNextDay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/transparent"
            app:srcCompat="@drawable/ic_chevron_right"
            app:tint="#94A3B8"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- KPI row: 3 cards -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKpiTotal"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#111B2E"
            app:layout_constraintTop_toBottomOf="@id/btnPrevDay"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/cardKpiSessions"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="1">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/iconBgTotal"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#0A2A3A"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        app:srcCompat="@drawable/ic_phone"
                        app:tint="#22D3EE" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvTotalLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Tiempo total"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/iconBgTotal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- VALUE FLEXIBLE: deja sitio fijo al Unit -->
                <TextView
                    android:id="@+id/tvTotalValue"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="22sp"
                    android:autoSizeMaxTextSize="30sp"
                    android:autoSizeStepGranularity="1sp"
                    app:layout_constraintTop_toBottomOf="@id/tvTotalLabel"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tvTotalUnit"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvTotalUnit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:includeFontPadding="true"
                    android:paddingBottom="2dp"
                    android:maxLines="1"
                    android:text="min"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tvTotalValue"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:ignore="HardcodedText" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKpiSessions"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_marginTop="14dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#111B2E"
            app:layout_constraintTop_toBottomOf="@id/btnPrevDay"
            app:layout_constraintStart_toEndOf="@id/cardKpiTotal"
            app:layout_constraintEnd_toStartOf="@id/cardKpiNight"
            app:layout_constraintHorizontal_weight="1">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/iconBgSessions"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#2A1430"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        app:srcCompat="@drawable/ic_sync"
                        app:tint="#F472B6" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvSessionsLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Nº sesiones"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/iconBgSessions"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvSessionsValue"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="22sp"
                    android:autoSizeMaxTextSize="30sp"
                    android:autoSizeStepGranularity="1sp"
                    app:layout_constraintTop_toBottomOf="@id/tvSessionsLabel"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tvSessionsUnit"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvSessionsUnit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:includeFontPadding="true"
                    android:paddingBottom="2dp"
                    android:maxLines="1"
                    android:text="aperturas"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tvSessionsValue"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:ignore="HardcodedText" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKpiNight"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_marginTop="14dp"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#111B2E"
            app:layout_constraintTop_toBottomOf="@id/btnPrevDay"
            app:layout_constraintStart_toEndOf="@id/cardKpiSessions"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/iconBgNight"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#2A240F"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        app:srcCompat="@drawable/ic_moon"
                        app:tint="#FBBF24" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvNightLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Uso noche"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/iconBgNight"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvNightValue"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="22sp"
                    android:autoSizeMaxTextSize="30sp"
                    android:autoSizeStepGranularity="1sp"
                    app:layout_constraintTop_toBottomOf="@id/tvNightLabel"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tvNightUnit"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvNightUnit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:includeFontPadding="true"
                    android:paddingBottom="2dp"
                    android:maxLines="1"
                    android:text="min"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tvNightValue"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:ignore="HardcodedText" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Chart 1 title -->
        <TextView
            android:id="@+id/tvDailyScreenTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Actividad diurna (07h-21h)"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/cardKpiTotal"
            app:layout_constraintStart_toStartOf="parent"
            tools:ignore="HardcodedText" />

        <!-- Chart 1 card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDailyLine"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#0E1729"
            app:layout_constraintTop_toBottomOf="@id/tvDailyScreenTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/lineChart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Chart 2 title -->
        <TextView
            android:id="@+id/tvNightActivityTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Uso nocturno (22:00–06:00)"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/cardDailyLine"
            app:layout_constraintStart_toStartOf="parent"
            tools:ignore="HardcodedText" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNightBars"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#0E1729"
            app:layout_constraintTop_toBottomOf="@id/tvNightActivityTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- Strip (timeline) -->
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChartNight"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Labels -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/nightLabelsRow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:layout_constraintTop_toBottomOf="@id/barChartNight"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/tvNight22"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="22:00"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvNight00"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.25"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvNight02"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="02:00"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.5"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvNight04"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="04:00"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.75"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvNight06"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="06:00"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Summary (si no hay pantalla detalle) -->
                <LinearLayout
                    android:id="@+id/nightSummary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/nightLabelsRow"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/tvNightTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uso total: --"
                        android:textColor="#CBD5E1"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/tvNightActiveHours"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Horas activas: --"
                        android:textColor="#CBD5E1"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>


    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
