<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/commsScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#0B1220"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/commsRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Top bar: back + title -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            app:srcCompat="@drawable/ic_arrow_back"
            app:tint="@android:color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/communications_title"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBack"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            tools:ignore="HardcodedText" />

        <!-- Day selector row -->
        <ImageButton
            android:id="@+id/btnPrevDay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/transparent"
            app:srcCompat="@drawable/ic_chevron_left"
            app:tint="#94A3B8"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvDayLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/today"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toTopOf="@id/btnPrevDay"
            app:layout_constraintBottom_toBottomOf="@id/btnPrevDay"
            app:layout_constraintStart_toEndOf="@id/btnPrevDay"
            app:layout_constraintEnd_toStartOf="@id/btnNextDay"
            app:layout_constraintHorizontal_bias="0.5"
            tools:ignore="HardcodedText" />

        <ImageButton
            android:id="@+id/btnNextDay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/transparent"
            app:srcCompat="@drawable/ic_chevron_right"
            app:tint="#94A3B8"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- KPI row: 3 cards -->
        <!-- KPI 1: Llamadas -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKpiCalls"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#111B2E"
            app:layout_constraintTop_toBottomOf="@id/btnPrevDay"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/cardKpiMsgs"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="1">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/iconBgCalls"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#2A240F"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        app:srcCompat="@drawable/ic_call"
                        app:tint="#FBBF24" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvCallsLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/calls"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/iconBgCalls"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvCallsValue"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="22sp"
                    android:autoSizeMaxTextSize="30sp"
                    android:autoSizeStepGranularity="1sp"
                    app:layout_constraintTop_toBottomOf="@id/tvCallsLabel"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tvCallsUnit"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvCallsUnit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:text="@string/total"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tvCallsValue"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:ignore="HardcodedText" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- KPI 2: Mensajes -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKpiMsgs"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_marginTop="14dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#111B2E"
            app:layout_constraintTop_toBottomOf="@id/btnPrevDay"
            app:layout_constraintStart_toEndOf="@id/cardKpiCalls"
            app:layout_constraintEnd_toStartOf="@id/cardKpiDur"
            app:layout_constraintHorizontal_weight="1">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/iconBgMsgs"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#0F253E"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        app:srcCompat="@drawable/ic_chat"
                        app:tint="#22D3EE" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvMsgsLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/messages"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/iconBgMsgs"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvMsgsValue"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="22sp"
                    android:autoSizeMaxTextSize="30sp"
                    android:autoSizeStepGranularity="1sp"
                    app:layout_constraintTop_toBottomOf="@id/tvMsgsLabel"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tvMsgsUnit"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvMsgsUnit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:text="@string/received"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tvMsgsValue"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:ignore="HardcodedText" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- KPI 3: Duración -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKpiDur"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_marginTop="14dp"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#111B2E"
            app:layout_constraintTop_toBottomOf="@id/btnPrevDay"
            app:layout_constraintStart_toEndOf="@id/cardKpiMsgs"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/iconBgDur"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#2A1430"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        app:srcCompat="@drawable/ic_timer"
                        app:tint="#F472B6" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvDurLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/duration"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/iconBgDur"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvDurValue"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="20sp"
                    android:autoSizeMaxTextSize="28sp"
                    android:autoSizeStepGranularity="1sp"
                    app:layout_constraintTop_toBottomOf="@id/tvDurLabel"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tvDurUnit"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvDurUnit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:text="@string/minutes_abv"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tvDurValue"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:ignore="HardcodedText" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Chart 1 title (FIRST) -->
        <TextView
            android:id="@+id/tvIntensityTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/communication_intensity_hour"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/cardKpiCalls"
            app:layout_constraintStart_toStartOf="parent"
            tools:ignore="HardcodedText" />

        <!-- Chart 1 card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIntensityChart"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#0E1729"
            app:layout_constraintTop_toBottomOf="@id/tvIntensityTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartIntensity"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Chart 2 title (SECOND) -->
        <TextView
            android:id="@+id/tvChannelDistTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/channel_distribution"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/cardIntensityChart"
            app:layout_constraintStart_toStartOf="parent"
            tools:ignore="HardcodedText" />

        <!-- Chart 2 card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardChannelDistChart"
            android:layout_width="0dp"
            android:layout_height="240dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#0E1729"
            app:layout_constraintTop_toBottomOf="@id/tvChannelDistTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/chartChannelDistStacked"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp" />

        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>