<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/notificationsScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#0B1220"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/notificationsRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Top bar: back + title -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            app:srcCompat="@drawable/ic_chevron_left"
            app:tint="@android:color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/notifications_title"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBack"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            tools:ignore="HardcodedText" />

        <!-- Day selector row -->
        <ImageButton
            android:id="@+id/btnPrevDay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/transparent"
            app:srcCompat="@drawable/ic_chevron_left"
            app:tint="#94A3B8"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvDayLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/notifications_today_label"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toTopOf="@id/btnPrevDay"
            app:layout_constraintBottom_toBottomOf="@id/btnPrevDay"
            app:layout_constraintStart_toEndOf="@id/btnPrevDay"
            app:layout_constraintEnd_toStartOf="@id/btnNextDay"
            app:layout_constraintHorizontal_bias="0.5"
            tools:ignore="HardcodedText" />

        <ImageButton
            android:id="@+id/btnNextDay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/transparent"
            app:srcCompat="@drawable/ic_chevron_right"
            app:tint="#94A3B8"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- KPI row: 3 cards -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKpi1"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#111B2E"
            app:layout_constraintTop_toBottomOf="@id/btnPrevDay"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/cardKpi2"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="1">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/iconBgKpi1"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#2A1430"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        app:srcCompat="@drawable/ic_notifications"
                        app:tint="#F472B6" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvKpi1Label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/notifications_daily_total_label"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/iconBgKpi1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvTotalNotifsValue"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="22sp"
                    android:autoSizeMaxTextSize="30sp"
                    android:autoSizeStepGranularity="1sp"
                    app:layout_constraintTop_toBottomOf="@id/tvKpi1Label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tvKpi1Unit"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvKpi1Unit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:text="@string/notifications_daily_total_unit"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tvTotalNotifsValue"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:ignore="HardcodedText" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKpi2"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_marginTop="14dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#111B2E"
            app:layout_constraintTop_toBottomOf="@id/btnPrevDay"
            app:layout_constraintStart_toEndOf="@id/cardKpi1"
            app:layout_constraintEnd_toStartOf="@id/cardKpi3"
            app:layout_constraintHorizontal_weight="1">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/iconBgKpi2"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#0F253E"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        app:srcCompat="@drawable/ic_trending_up"
                        app:tint="#22D3EE" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvKpi2Label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/notifications_avg_per_hour_label"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/iconBgKpi2"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvAvgPerHourValue"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="22sp"
                    android:autoSizeMaxTextSize="30sp"
                    android:autoSizeStepGranularity="1sp"
                    app:layout_constraintTop_toBottomOf="@id/tvKpi2Label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tvKpi2Unit"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvKpi2Unit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:text="@string/notifications_avg_per_hour_unit"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tvAvgPerHourValue"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:ignore="HardcodedText" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKpi3"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_marginTop="14dp"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#111B2E"
            app:layout_constraintTop_toBottomOf="@id/btnPrevDay"
            app:layout_constraintStart_toEndOf="@id/cardKpi2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/iconBgKpi3"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#2A240F"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        app:srcCompat="@drawable/ic_phone"
                        app:tint="#FBBF24" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvKpi3Label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/notifications_most_intrusive_app_label"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/iconBgKpi3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvMostIntrusiveValue"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="--"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="18sp"
                    android:autoSizeMaxTextSize="26sp"
                    android:autoSizeStepGranularity="1sp"
                    app:layout_constraintTop_toBottomOf="@id/tvKpi3Label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:ignore="HardcodedText" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Trend title -->
        <TextView
            android:id="@+id/tvTrendTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/notifications_most_intrusive_app_label"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/cardKpi1"
            app:layout_constraintStart_toStartOf="parent"
            tools:ignore="HardcodedText" />

        <!-- Trend chart card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNotifsChart"
            android:layout_width="0dp"
            android:layout_height="210dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#0E1729"
            app:layout_constraintTop_toBottomOf="@id/tvTrendTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartNotifs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Top apps title -->
        <TextView
            android:id="@+id/tvTopNotifsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/notifications_top_apps_title"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/cardNotifsChart"
            app:layout_constraintStart_toStartOf="parent"
            tools:ignore="HardcodedText" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTopNotifsApps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#0E1729"
            app:layout_constraintTop_toBottomOf="@id/tvTopNotifsTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp">

                    <TextView
                        android:id="@+id/tvApp1Name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        tools:text="Slack" />

                    <ProgressBar
                        android:id="@+id/pbApp1"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="90dp"
                        android:layout_height="6dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#22D3EE"
                        android:progressBackgroundTint="#273244" />

                    <TextView
                        android:id="@+id/tvApp1Pct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="--%"
                        android:textColor="#CBD5E1"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1E2A44" />

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp">

                    <TextView
                        android:id="@+id/tvApp2Name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        tools:text="Instagram" />

                    <ProgressBar
                        android:id="@+id/pbApp2"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="90dp"
                        android:layout_height="6dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#22C55E"
                        android:progressBackgroundTint="#273244" />

                    <TextView
                        android:id="@+id/tvApp2Pct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="--%"
                        android:textColor="#CBD5E1"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1E2A44" />

                <!-- Row 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp">

                    <TextView
                        android:id="@+id/tvApp3Name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        tools:text="WhatsApp" />

                    <ProgressBar
                        android:id="@+id/pbApp3"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="90dp"
                        android:layout_height="6dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#A78BFA"
                        android:progressBackgroundTint="#273244" />

                    <TextView
                        android:id="@+id/tvApp3Pct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="--%"
                        android:textColor="#CBD5E1"
                        android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Notification types title -->
        <TextView
            android:id="@+id/tvNotifTypesTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/notifications_types_title"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/cardTopNotifsApps"
            app:layout_constraintStart_toStartOf="parent"
            tools:ignore="HardcodedText" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNotifTypesChart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2A44"
            app:cardBackgroundColor="#0E1729"
            app:layout_constraintTop_toBottomOf="@id/tvNotifTypesTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <com.github.mikephil.charting.charts.HorizontalBarChart
                    android:id="@+id/chartNotifTypesStacked"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="8dp" />

                <!-- Mini-leyenda (1 línea) -->
                <LinearLayout
                    android:id="@+id/legendNotifTypes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>