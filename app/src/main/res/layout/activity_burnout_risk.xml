<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="#0B1220">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp"
            tools:context="gal.uvigo.burnout_app.ui.BurnoutRiskActivity">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                app:srcCompat="@drawable/ic_arrow_back"
                app:tint="@android:color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/burnout_title"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="@id/btnBack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/btnBack" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRiskScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                app:cardBackgroundColor="#111B2E"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E2A44"
                app:strokeWidth="1dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnBack">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/tvRiskScoreCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivInfoScore"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <ImageView
                        android:id="@+id/ivInfoScore"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:srcCompat="@drawable/ic_info"
                        app:tint="@android:color/white"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- RESUMEN RIESGO ACTUAL -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCurrentRisk"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                app:cardBackgroundColor="#111B2E"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E2A44"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardRiskScore">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/iconRiskBg"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginTop="4dp"
                        app:cardBackgroundColor="#3A2A0A"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/ivRiskIcon"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            app:srcCompat="@drawable/ic_warning"
                            app:tint="#FACC15" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvRiskLevel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginTop="2dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="26sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iconRiskBg"
                        app:layout_constraintTop_toTopOf="@id/iconRiskBg" />

                    <TextView
                        android:id="@+id/tvDriversTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/burnout_main_drivers_title"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/iconRiskBg" />

                    <TextView
                        android:id="@+id/tvDriver1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:drawablePadding="8dp"
                        app:drawableTint="@android:color/white"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvDriversTitle" />

                    <TextView
                        android:id="@+id/tvDriver2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:drawablePadding="8dp"
                        app:drawableTint="@android:color/white"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvDriver1" />

                    <TextView
                        android:id="@+id/tvDriver3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:drawablePadding="8dp"
                        app:drawableTint="@android:color/white"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvDriver2" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TENDENCIA -->
            <TextView
                android:id="@+id/tvTrendTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/burnout_trend_title"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardCurrentRisk" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTrend"
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#0E1729"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E2A44"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTrendTitle">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChartRiskTrend"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ANALISIS POR DIMENSION -->
            <TextView
                android:id="@+id/tvDimensionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/burnout_dimension_analysis_title"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardTrend" />

            <!-- Fragmentación -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDimensionFragmentation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#111B2E"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E2A44"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvDimensionTitle">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/iconBgFrag"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        app:cardBackgroundColor="#2A1430"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            app:srcCompat="@drawable/ic_sync"
                            app:tint="#F472B6" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvFragLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/burnout_dimension_fragmentation"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        app:layout_constraintEnd_toStartOf="@id/tvFragLevel"
                        app:layout_constraintStart_toEndOf="@id/iconBgFrag"
                        app:layout_constraintTop_toTopOf="@id/iconBgFrag" />

                    <TextView
                        android:id="@+id/tvFragLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/iconBgFrag" />

                    <TextView
                        android:id="@+id/tvFragValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iconBgFrag"
                        app:layout_constraintTop_toBottomOf="@id/tvFragLabel" />

                    <TextView
                        android:id="@+id/tvFragBaseline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/iconBgFrag" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Uso nocturno -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDimensionNight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#111B2E"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E2A44"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardDimensionFragmentation">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/iconBgNight"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        app:cardBackgroundColor="#0F253E"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            app:srcCompat="@drawable/ic_moon"
                            app:tint="#FACC15" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvNightLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/screen_time_night_label"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        app:layout_constraintEnd_toStartOf="@id/tvNightLevel"
                        app:layout_constraintStart_toEndOf="@id/iconBgNight"
                        app:layout_constraintTop_toTopOf="@id/iconBgNight" />

                    <TextView
                        android:id="@+id/tvNightLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/iconBgNight" />

                    <TextView
                        android:id="@+id/tvNightValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iconBgNight"
                        app:layout_constraintTop_toBottomOf="@id/tvNightLabel" />

                    <TextView
                        android:id="@+id/tvNightBaseline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/iconBgNight" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Notificaciones -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDimensionNotifications"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#111B2E"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E2A44"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardDimensionNight">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/iconBgNotif"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        app:cardBackgroundColor="#0F2D22"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            app:srcCompat="@drawable/ic_notifications"
                            app:tint="#34D399" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvNotifLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/notifications_chart_dataset"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        app:layout_constraintEnd_toStartOf="@id/tvNotifLevel"
                        app:layout_constraintStart_toEndOf="@id/iconBgNotif"
                        app:layout_constraintTop_toTopOf="@id/iconBgNotif" />

                    <TextView
                        android:id="@+id/tvNotifLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/iconBgNotif" />

                    <TextView
                        android:id="@+id/tvNotifValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iconBgNotif"
                        app:layout_constraintTop_toBottomOf="@id/tvNotifLabel" />

                    <TextView
                        android:id="@+id/tvNotifBaseline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/iconBgNotif" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tiempo de pantalla -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDimensionScreen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#111B2E"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E2A44"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardDimensionNotifications">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/iconBgScreen"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        app:cardBackgroundColor="#0F253E"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            app:srcCompat="@drawable/ic_phone"
                            app:tint="#60A5FA" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvScreenLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/main_screen_time_label"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        app:layout_constraintEnd_toStartOf="@id/tvScreenLevel"
                        app:layout_constraintStart_toEndOf="@id/iconBgScreen"
                        app:layout_constraintTop_toTopOf="@id/iconBgScreen" />

                    <TextView
                        android:id="@+id/tvScreenLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/iconBgScreen" />

                    <TextView
                        android:id="@+id/tvScreenValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iconBgScreen"
                        app:layout_constraintTop_toBottomOf="@id/tvScreenLabel" />

                    <TextView
                        android:id="@+id/tvScreenBaseline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/iconBgScreen" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tendencia / desviación -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDimensionTrend"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#111B2E"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E2A44"
                app:strokeWidth="1dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardDimensionScreen">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/iconBgTrend"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        app:cardBackgroundColor="#3A2A0A"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            app:srcCompat="@drawable/ic_trending_up"
                            app:tint="#FACC15" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvTrendDimLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/burnout_dimension_trend"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        app:layout_constraintEnd_toStartOf="@id/tvTrendDimLevel"
                        app:layout_constraintStart_toEndOf="@id/iconBgTrend"
                        app:layout_constraintTop_toTopOf="@id/iconBgTrend" />

                    <TextView
                        android:id="@+id/tvTrendDimLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/iconBgTrend" />

                    <TextView
                        android:id="@+id/tvTrendDimValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iconBgTrend"
                        app:layout_constraintTop_toBottomOf="@id/tvTrendDimLabel" />

                    <TextView
                        android:id="@+id/tvTrendDimBaseline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/format_marker_empty"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/iconBgTrend" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#0B0F1A"
        android:clipToPadding="false"
        android:fitsSystemWindows="true"
        android:paddingTop="16dp"
        app:headerLayout="@layout/drawer_header"
        app:itemHorizontalPadding="20dp"
        app:itemIconPadding="16dp"
        app:itemIconTint="@null"
        app:itemTextColor="@android:color/white"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>